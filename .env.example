DATABASE_URL=postgresql://studylab:studylab@localhost:5432/studylab
# Durable local persistence. Leave unset to use the in-memory store (tests/ephemeral).
STUDYLAB_SQLITE_PATH=
PORT=8000
RAG_PORT=8001
SOLVER_PORT=8002
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=source_chunks
RAG_RETRIEVER=local_hybrid
RAG_TOP_K=4
RAG_CANDIDATE_K=40
RAG_MIN_SCORE=0.16
FRONTIER_API_KEY=
OPENWEIGHT_ENDPOINT=http://localhost:8101
EMBEDDINGS_ENDPOINT=http://localhost:8102
SANDBOX_ENDPOINT=http://localhost:8103
NOTION_API_KEY=
NOTION_MOCK_EXPORT=true
CACHE_TTL=604800
# Phase 3: Voice input/output. Falls back to mock mode when not set.
GEMINI_API_KEY=
# Phase 4: Billing. Falls back to the mock billing provider when not set.
STRIPE_API_KEY=
STRIPE_SUCCESS_URL=https://example.com/billing/success
STRIPE_CANCEL_URL=https://example.com/billing/cancel
# Phase 5: Production readiness (auth + quota enforcement).
# JWT signing secret. A dev fallback is used if unset — set a strong value in production.
STUDYLAB_JWT_SECRET=
# Set true to require a valid Bearer token on all non-public gateway routes.
STUDYLAB_REQUIRE_AUTH=false
# Set true to hard-enforce plan quotas (over-quota metered actions return HTTP 402).
STUDYLAB_ENFORCE_QUOTAS=false
